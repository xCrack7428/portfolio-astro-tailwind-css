						>HTML5</span
					>
					<span
						class="flex items-center gap-2 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 px-4 py-2 rounded-lg text-sm font-medium hover:border-blue-500 hover:text-blue-500 dark:hover:text-blue-400 transition-colors shadow-sm dark:shadow-none"
						>CSS3</span
