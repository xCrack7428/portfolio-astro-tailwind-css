									class="text-blue-500 dark:text-blue-400 hover:text-blue-600 dark:hover:text-blue-300 font-medium inline-flex items-center gap-1 group-hover:underline text-sm transition-colors"
								>
									Ver Demo →
								</a>
							</div>
						</div>
					</div>

					<div
						class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden group hover:border-red-500 dark:hover:border-red-500 transition-all duration-300 shadow-xl dark:shadow-lg flex flex-col"
					>
						<img
							src="https://www.phpzag.com/wp-content/uploads/2021/03/crud-operation-laravel-min.png"
							alt="CRUD Básico de Productos en Laravel"
