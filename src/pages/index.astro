								<span
									class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-3 py-1 rounded-full text-xs font-medium transition-colors"
									>REST API</span
								>
								<span
									class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-3 py-1 rounded-full text-xs font-medium transition-colors"
									>TAILWIND CSS</span
								>
							</div>

							<div
								class="flex gap-4 mt-auto border-t border-gray-200 dark:border-gray-800 pt-6 flex-wrap transition-colors"
							>
								<a
									href="https://github.com/xCrack7428/xCrack7428-Valorant-DIW"
									target="_blank"
									class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white font-medium inline-flex items-center gap-1 transition-colors text-sm"
								>
