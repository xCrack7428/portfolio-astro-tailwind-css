						alt="Logo DAW"
						class="w-full h-full object-contain"
					/>
				</div>
			</header>

			<section class="mb-24">
				<h2
					class="text-2xl font-bold mb-8 text-gray-900 dark:text-white tracking-tight flex items-center gap-3 transition-colors"
