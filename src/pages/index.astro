---

---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Portfolio | Mario Moñino Larrosa</title>
	</head>
	<body
		class="bg-gray-950 text-gray-100 font-sans antialiased selection:bg-blue-500 selection:text-white"
	>
		<main class="max-w-4xl mx-auto px-6 py-12 md:py-24">
			<header
				class="mb-24 flex flex-col md:flex-row items-center gap-12 border-b border-gray-800 pb-16"
			>
				<div class="flex-1 text-center md:text-left">
					<h1
						class="text-5xl md:text-7xl font-extrabold mb-4 tracking-tighter text-white"
					>
						Hola, soy <span class="text-blue-400"
							>Mario Moñino Larrosa</span
						>
					</h1>
					<p
						class="text-xl md:text-2xl text-gray-400 leading-relaxed max-w-2xl mx-auto md:mx-0"
					>
						Desarrollador web. Me especializo en crear páginas webs
						con interfaces muy llamativas, rápidas y efectivas.
					</p>
				</div>

				<div
					class="w-40 h-40 md:w-48 md:h-48 rounded-full border-4 border-blue-600 shadow-xl overflow-hidden bg-white p-2 flex items-center justify-center"
				>
					<img
						src="https://iespacomolla.es/wp-content/uploads/2019/05/thumbnail-daw.png"
						alt="Logo DAW"
						class="w-full h-full object-contain"
					/>
				</div>
			</header>

			<section class="mb-24">
				<h2
					class="text-3xl font-bold mb-10 text-white tracking-tight flex items-center gap-3"
				>
					<span class="w-10 h-1 md:w-16 bg-blue-500 rounded"></span>
					Proyectos Destacados
				</h2>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-10">
					<div
						class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden group hover:border-blue-400 transition-all duration-300 shadow-lg hover:shadow-blue-900/30 flex flex-col"
					>
						<img
							src="https://xcrack7428.github.io/xCrack7428-Valorant-DIW/img/DAWLORANT.png"
							alt="DAWLORANT Project Screenshot"
							class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300"
						/>
						<div class="p-8 flex-1 flex flex-col">
							<h3
								class="text-2xl font-semibold mb-3 text-white group-hover:text-blue-400"
							>
								Landing de Valorant con API
							</h3>
							<p
								class="text-gray-400 text-base leading-relaxed mb-6 flex-1"
							>
								Una landing page personalizada de Valorant que
								se conecta y consume datos en tiempo real de la
								API oficial para mostrar información
								actualizada.
							</p>
							<div class="flex gap-3 mb-6 flex-wrap">
								<span
									class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-medium"
									>HTML/CSS</span
								>
								<span
									class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-medium"
									>JavaScript</span
								>
								<span
									class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-medium"
									>REST API</span
								>
								<span
									class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-medium"
									>TAILWIND CSS</span
								>
							</div>

							<div class="flex gap-4 mt-auto">
								<a
									href="https://github.com/xCrack7428/xCrack7428-Valorant-DIW"
									target="_blank"
									class="text-gray-400 hover:text-white font-medium inline-flex items-center gap-1 transition-colors"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="18"
										height="18"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-7.5 0-1.6-.6-3-1.5-4 .1-.4.6-2-.1-4.2 0 0-1.2-.4-4 1.5-1.1-.3-2.3-.5-3.5-.5s-2.4.2-3.5.5C4.2 2 3 2 3 2c-.7 2.2-.2 3.8-.1 4.2-.9 1-1.5 2.4-1.5 4 0 6 3 7.2 6 7.5-.4.3-.7.9-.8 2-.5.2-1.7.5-2.5-.7-.8-1.5-2-1.5-2-1.5-1.2 0-.2.1-.2.1 1.2.5 1.7 2.2 1.7 2.2.8 1.5 2.5 1.5 3.5 1.2v2.2"
										></path></svg
									>
									Código
								</a>
								<a
									href="https://xcrack7428.github.io/xCrack7428-Valorant-DIW/"
									target="_blank"
									class="text-blue-400 hover:text-blue-300 font-medium inline-flex items-center gap-1 group-hover:underline"
								>
									Ver Demo →
								</a>
							</div>
						</div>
					</div>

					<div
						class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden group hover:border-red-500 transition-all duration-300 shadow-lg hover:shadow-red-900/30 flex flex-col"
					>
						<img
							src="https://www.phpzag.com/wp-content/uploads/2021/03/crud-operation-laravel-min.png"
							alt="CRUD Básico de Productos en Laravel"
							class="w-full h-56 object-cover group-hover:scale-105 transition-transform duration-300 opacity-80 group-hover:opacity-100"
						/>
						<div class="p-8 flex-1 flex flex-col">
							<h3
								class="text-2xl font-semibold mb-3 text-white group-hover:text-red-400"
							>
								CRUD Básico en Laravel
							</h3>
							<p
								class="text-gray-400 text-base leading-relaxed mb-6 flex-1"
							>
								Un sistema de gestión de productos que permite
								crear, leer, actualizar y eliminar registros
								utilizando la arquitectura MVC y migraciones del
								framework Laravel.
							</p>
							<div class="flex gap-3 mb-6 flex-wrap">
								<span
									class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-medium"
									>Laravel</span
								>
								<span
									class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-medium"
									>PHP</span
								>
								<span
									class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-medium"
									>MySQL</span
								>
							</div>

							<div class="flex gap-4 mt-auto">
								<a
									href="https://github.com/xCrack7428/crud-laravel-basico"
									target="_blank"
									class="text-gray-400 hover:text-white font-medium inline-flex items-center gap-1 transition-colors"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="18"
										height="18"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-7.5 0-1.6-.6-3-1.5-4 .1-.4.6-2-.1-4.2 0 0-1.2-.4-4 1.5-1.1-.3-2.3-.5-3.5-.5s-2.4.2-3.5.5C4.2 2 3 2 3 2c-.7 2.2-.2 3.8-.1 4.2-.9 1-1.5 2.4-1.5 4 0 6 3 7.2 6 7.5-.4.3-.7.9-.8 2-.5.2-1.7.5-2.5-.7-.8-1.5-2-1.5-2-1.5-1.2 0-.2.1-.2.1 1.2.5 1.7 2.2 1.7 2.2.8 1.5 2.5 1.5 3.5 1.2v2.2"
										></path></svg
									>
									Código
								</a>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section
				class="bg-gray-900 border border-gray-800 rounded-3xl p-12 text-center shadow-inner"
			>
				<h2 class="text-3xl font-bold mb-4 text-white">Contacto</h2>
				<p class="text-lg text-gray-400 mb-10 max-w-xl mx-auto">
					¿Tienes un proyecto en mente o quieres investigar mis
					proyectos? Échales un vistazo!!!
				</p>

				<div class="flex gap-5 justify-center flex-wrap">
					<a
						href="https://mail.google.com/mail/u/3/#inbox?compose=new"
						target="_blank"
						class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-full font-semibold transition-all shadow-md hover:scale-105"
					>
						Escríbeme
					</a>
					<a
						href="https://github.com/xCrack7428"
						target="_blank"
						class="bg-gray-800 hover:bg-gray-700 border border-gray-700 text-white px-8 py-3 rounded-full font-semibold transition-all flex items-center gap-2"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="20"
							height="20"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							><path
								d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-7.5 0-1.6-.6-3-1.5-4 .1-.4.6-2-.1-4.2 0 0-1.2-.4-4 1.5-1.1-.3-2.3-.5-3.5-.5s-2.4.2-3.5.5C4.2 2 3 2 3 2c-.7 2.2-.2 3.8-.1 4.2-.9 1-1.5 2.4-1.5 4 0 6 3 7.2 6 7.5-.4.3-.7.9-.8 2-.5.2-1.7.5-2.5-.7-.8-1.5-2-1.5-2-1.5-1.2 0-.2.1-.2.1 1.2.5 1.7 2.2 1.7 2.2.8 1.5 2.5 1.5 3.5 1.2v2.2"
							></path></svg
						>
						GitHub
					</a>
				</div>
			</section>

			<footer class="mt-20 text-center text-gray-500 text-sm">
				<p>© {new Date().getFullYear()} Mario Moñino Larrosa.</p>
			</footer>
		</main>
	</body>
</html>
