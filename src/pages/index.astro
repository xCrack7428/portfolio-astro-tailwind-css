						/>
						<div class="p-8 flex-1 flex flex-col">
							<h3
								class="text-2xl font-semibold mb-3 text-gray-900 dark:text-white group-hover:text-red-500 dark:group-hover:text-red-400 transition-colors"
							>
								CRUD Básico en Laravel
							</h3>
							<p
								class="text-gray-600 dark:text-gray-400 text-base leading-relaxed mb-6 flex-1 transition-colors"
							>
								Un sistema de gestión de productos que permite
								crear, leer, actualizar y eliminar registros
								utilizando la arquitectura MVC y migraciones del
								framework Laravel.
							</p>
							<div class="flex gap-3 mb-6 flex-wrap">
								<span
									class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-3 py-1 rounded-full text-xs font-medium transition-colors"
									>Laravel</span
								>
								<span
									class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-3 py-1 rounded-full text-xs font-medium transition-colors"
									>PHP</span
								>
								<span
									class="bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 px-3 py-1 rounded-full text-xs font-medium transition-colors"
									>MySQL</span
								>
							</div>

							<div
								class="flex gap-4 mt-auto border-t border-gray-200 dark:border-gray-800 pt-6 flex-wrap transition-colors"
							>
								<a
									href="https://github.com/xCrack7428/crud-laravel-basico"
									target="_blank"
									class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white font-medium inline-flex items-center gap-1 transition-colors text-sm"
								>
									<svg
										xmlns="http://www.w3.org/2000/svg"
										width="16"
										height="16"
										viewBox="0 0 24 24"
										fill="none"
										stroke="currentColor"
										stroke-width="2"
										stroke-linecap="round"
										stroke-linejoin="round"
										><path
											d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-7.5 0-1.6-.6-3-1.5-4 .1-.4.6-2-.1-4.2 0 0-1.2-.4-4 1.5-1.1-.3-2.3-.5-3.5-.5s-2.4.2-3.5.5C4.2 2 3 2 3 2c-.7 2.2-.2 3.8-.1 4.2-.9 1-1.5 2.4-1.5 4 0 6 3 7.2 6 7.5-.4.3-.7.9-.8 2-.5.2-1.7.5-2.5-.7-.8-1.5-2-1.5-2-1.5-1.2 0-.2.1-.2.1 1.2.5 1.7 2.2 1.7 2.2.8 1.5 2.5 1.5 3.5 1.2v2.2"
										></path></svg
									>
									Código
								</a>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section
				class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl p-8 md:p-12 shadow-xl dark:shadow-inner transition-colors"
			>
				<div class="text-center mb-10">
					<h2
						class="text-3xl font-bold mb-4 text-gray-900 dark:text-white transition-colors"
					>
						¿Hablamos?
					</h2>
					<p
						class="text-lg text-gray-600 dark:text-gray-400 max-w-xl mx-auto transition-colors"
					>
						¿Tienes un proyecto en mente o quieres investigar mis
						proyectos? Envíame un mensaje directo o contáctame por
						mis redes.
					</p>
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
					<form
						action="https://formsubmit.co/TU_CORREO@gmail.com"
						method="POST"
						class="flex flex-col gap-5"
					>
						<input
							type="hidden"
							name="_subject"
							value="Nuevo mensaje desde tu Portfolio!"
						/>
						<input type="hidden" name="_captcha" value="false" />
						<input type="hidden" name="_template" value="table" />

						<div>
							<label
								for="name"
								class="block text-sm font-medium text-gray-700 dark:text-gray-400 mb-1 transition-colors"
								>Nombre</label
							>
							<input
								type="text"
								id="name"
								name="name"
								placeholder="Tu nombre"
								required
								class="w-full bg-gray-50 dark:bg-gray-950 border border-gray-200 dark:border-gray-800 rounded-lg px-4 py-3 text-gray-900 dark:text-white focus:outline-none focus:border-blue-500 transition-colors"
							/>
						</div>
						<div>
							<label
								for="email"
								class="block text-sm font-medium text-gray-700 dark:text-gray-400 mb-1 transition-colors"
								>Correo Electrónico</label
							>
							<input
								type="email"
								id="email"
								name="email"
								placeholder="tu@email.com"
								required
								class="w-full bg-gray-50 dark:bg-gray-950 border border-gray-200 dark:border-gray-800 rounded-lg px-4 py-3 text-gray-900 dark:text-white focus:outline-none focus:border-blue-500 transition-colors"
							/>
						</div>
						<div>
							<label
								for="message"
								class="block text-sm font-medium text-gray-700 dark:text-gray-400 mb-1 transition-colors"
								>Mensaje</label
							>
							<textarea
								id="message"
								name="message"
								rows="4"
								placeholder="¿En qué te puedo ayudar?"
								required
								class="w-full bg-gray-50 dark:bg-gray-950 border border-gray-200 dark:border-gray-800 rounded-lg px-4 py-3 text-gray-900 dark:text-white focus:outline-none focus:border-blue-500 transition-colors resize-none"
							></textarea>
						</div>
						<button
							type="submit"
							class="w-full bg-blue-600 hover:bg-blue-700 dark:hover:bg-blue-500 text-white font-bold py-3 px-4 rounded-lg transition-colors mt-2"
						>
							Enviar Mensaje
						</button>
					</form>

					<div class="flex flex-col justify-center h-full gap-6">
						<div
							class="bg-gray-50 dark:bg-gray-950 border border-gray-200 dark:border-gray-800 p-6 rounded-xl transition-colors"
						>
							<h3
								class="text-xl font-semibold text-gray-900 dark:text-white mb-2 transition-colors"
							>
								Mi Repositorio
							</h3>
							<p
								class="text-gray-600 dark:text-gray-400 text-sm mb-6 transition-colors"
							>
								Puedes encontrar el código fuente de todos mis
								proyectos, prácticas y experimentos en mi perfil
								de GitHub.
							</p>
							<a
								href="https://github.com/xCrack7428"
								target="_blank"
								class="bg-gray-200 dark:bg-gray-800 hover:bg-gray-300 dark:hover:bg-gray-700 border border-gray-300 dark:border-gray-700 text-gray-900 dark:text-white px-6 py-3 rounded-lg font-semibold transition-all flex items-center justify-center gap-2 w-full"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									width="20"
									height="20"
									viewBox="0 0 24 24"
									fill="none"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"
									><path
										d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3-.3 6-1.5 6-7.5 0-1.6-.6-3-1.5-4 .1-.4.6-2-.1-4.2 0 0-1.2-.4-4 1.5-1.1-.3-2.3-.5-3.5-.5s-2.4.2-3.5.5C4.2 2 3 2 3 2c-.7 2.2-.2 3.8-.1 4.2-.9 1-1.5 2.4-1.5 4 0 6 3 7.2 6 7.5-.4.3-.7.9-.8 2-.5.2-1.7.5-2.5-.7-.8-1.5-2-1.5-2-1.5-1.2 0-.2.1-.2.1 1.2.5 1.7 2.2 1.7 2.2.8 1.5 2.5 1.5 3.5 1.2v2.2"
									></path></svg
								>
								Ver GitHub
							</a>
						</div>
					</div>
				</div>
			</section>

			<footer class="mt-20 text-center text-gray-500 text-sm">
				<p>
					© {new Date().getFullYear()} Mario Moñino Larrosa. Desarrollado
					con Astro y Tailwind CSS.
				</p>
			</footer>
		</main>

		<script>
			const themeToggleBtn = document.getElementById("themeToggle");

			if (themeToggleBtn) {
				themeToggleBtn.addEventListener("click", () => {
					const html = document.documentElement;

					if (html.classList.contains("dark")) {
						html.classList.remove("dark");
						localStorage.setItem("theme", "light");
					} else {
						html.classList.add("dark");
						localStorage.setItem("theme", "dark");
					}
				});
			}
		</script>
	</body>
</html>
