<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>Portfolio | Mario Moñino Larrosa</title>

		<script is:inline>
			const theme = (() => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
					return "dark";
				}
				return "light";
			})();
			if (theme === "light") {
				document.documentElement.classList.remove("dark");
			} else {
				document.documentElement.classList.add("dark");
			}
			window.localStorage.setItem("theme", theme);
		</script>
	</head>

	<body
		class="bg-gray-50 dark:bg-gray-950 text-gray-900 dark:text-gray-100 font-sans antialiased selection:bg-blue-500 selection:text-white transition-colors duration-300"
	>
		<main class="max-w-4xl mx-auto px-6 py-12 md:py-24 relative">
			<div class="absolute top-6 right-6 md:top-12 md:right-12">
				<button
					id="themeToggle"
					class="p-2 rounded-lg bg-gray-200 dark:bg-gray-800 text-gray-800 dark:text-gray-200 hover:bg-gray-300 dark:hover:bg-gray-700 transition-colors shadow-sm focus:outline-none"
				>
					<svg
						id="moon-icon"
						class="block dark:hidden w-5 h-5"
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"
						></path></svg
					>
					<svg
						id="sun-icon"
						class="hidden dark:block w-5 h-5"
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						><circle cx="12" cy="12" r="4"></circle><path
							d="M12 2v2"></path><path d="M12 20v2"></path><path
							d="m4.93 4.93 1.41 1.41"></path><path
							d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"
						></path><path d="M20 12h2"></path><path
							d="m6.34 17.66-1.41 1.41"></path><path
							d="m19.07 4.93-1.41 1.41"></path></svg
					>
				</button>
			</div>

			<header
				class="mb-20 flex flex-col md:flex-row items-center gap-12 border-b border-gray-200 dark:border-gray-800 pb-16 transition-colors mt-8"
			>
				<div class="flex-1 text-center md:text-left">
					<h1
						class="text-5xl md:text-7xl font-extrabold mb-4 tracking-tighter text-gray-900 dark:text-white transition-colors"
					>
						Hola, soy <span class="text-blue-500 dark:text-blue-400"
							>Mario Moñino Larrosa</span
						>.
					</h1>
					<p
						class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl mx-auto md:mx-0 transition-colors"
					>
						Desarrollador web. Me especializo en crear páginas webs
						con interfaces muy llamativas, rápidas y efectivas.
					</p>
				</div>

				<div
					class="w-40 h-40 md:w-48 md:h-48 rounded-full border-4 border-blue-500 dark:border-blue-600 shadow-xl overflow-hidden bg-white p-2 flex items-center justify-center transition-colors"
				>
					<img
